# Настройки базы данных PostgreSQL
# Формат: postgresql://пользователь:пароль@хост:порт/имя_базы
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gnezdo_db

# Секретный ключ для шифрования паролей и создания JWT-токенов (авторизация)
# В продакшене тут должна быть длинная случайная строка
SECRET_KEY=super_secret_key_for_gnezdo_mvp_2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 часа для удобства MVP

# Настройки CORS (кто может делать запросы к нашему API)
# Для локальной разработки фронтенда на Vite обычно используется порт 5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# API ключи для внешних сервисов (понадобятся позже)
# Например, для автоматической ИИ-проверки справок
VISION_API_KEY=your_yandex_or_google_api_key_here