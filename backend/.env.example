# Database PostgreSQL (Render создаст сам)
DATABASE_URL=

# Секретный ключ для JWT (придумай сложный)
SECRET_KEY=твой_сложный_ключ_здесь

# Алгоритм (не меняй)
ALGORITHM=HS256

# Время жизни токена в минутах (24 часа)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS - добавь адрес фронтенда после деплоя
ALLOWED_ORIGINS=http://localhost:5173