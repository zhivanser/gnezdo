{
  "$schema": "zeabur schema",
  "name": "gnezdo-api",
  "region": "ru-msk",
  "builder": "docker",
  "builderConfig": {
    "dockerfilePath": "backend/Dockerfile",
    "buildContext": "."
  },
  "package": {
    "command": "uvicorn main:app --host 0.0.0.0 --port 8080"
  },
  "env": {
    "DATABASE_URL": {
      "required": true
    },
    "SECRET_KEY": {
      "required": true
    },
    "ALGORITHM": "HS256",
    "ACCESS_TOKEN_EXPIRE_MINUTES": "1440",
    "ALLOWED_ORIGINS": "*"
  },
  "port": 8080
}